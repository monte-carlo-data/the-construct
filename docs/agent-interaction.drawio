          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== Dispatch buckets ===== -->
        <mxCell id="auto" value="&lt;b&gt;Auto-run&lt;/b&gt; — low-blast-radius analysis&lt;br&gt;&lt;font color=&#39;#94A3B8&#39; size=&#39;1&#39;&gt;trinity · merovingian · niobe · switch · oracle · seraph · carlton&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B3B36;strokeColor=#2DD4BF;fontColor=#E2E8F0;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
