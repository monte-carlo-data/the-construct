        <!-- ===== Security Steve orchestrator ===== -->
        <mxCell id="steve" value="&lt;b&gt;Security Steve — /security-steve orchestrate&lt;/b&gt;&lt;br&gt;&lt;font color=&#39;#94A3B8&#39; size=&#39;1&#39;&gt;cross-domain orchestrator · spans Context · Behavior · Intent&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#134E4A;strokeColor=#2DD4BF;fontColor=#FFFFFF;fontSize=14;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="560" y="556" width="480" height="56" as="geometry" />
        </mxCell>

        <!-- Zero Trust gate -->
        <mxCell id="gate" value="&lt;b&gt;Zero Trust gate&lt;/b&gt;&lt;br&gt;&lt;font color=&#39;#94A3B8&#39; size=&#39;1&#39;&gt;findings are untrusted between hops&lt;/font&gt;&lt;br&gt;&lt;font color=&#39;#CBD5E1&#39; size=&#39;1&#39;&gt;• act on structured fields, never the body&lt;br&gt;• validate suggested_next vs. matrix allow-set&lt;br&gt;• attribute provenance (emitting agent)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#F87171;fontColor=#E2E8F0;fontSize=12;align=left;spacingLeft=12;verticalAlign=middle;" vertex="1" parent="1">
