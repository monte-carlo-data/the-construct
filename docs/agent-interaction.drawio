        <!-- ===== Footnote ===== -->
        <mxCell id="foot" value="A handoff is agent→agent only; human-team remediation is named in the finding body. The cascade matrix (which finding-type routes to which agent) lives in findings/HANDOFF_PROTOCOL.md." style="text;html=1;align=left;verticalAlign=middle;fontColor=#64748B;fontSize=11;fontStyle=2;" vertex="1" parent="1">
