        <!-- ===== Findings ledger ===== -->
        <mxCell id="ledger" value="&lt;b&gt;findings/  — shared findings store&lt;/b&gt;&lt;br&gt;&lt;font color=&#39;#94A3B8&#39; size=&#39;1&#39;&gt;one markdown file per finding · id · agent · severity · status · suggested_next&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B1220;strokeColor=#475569;fontColor=#E2E8F0;fontSize=13;dashed=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="520" y="472" width="560" height="56" as="geometry" />
        </mxCell>

        <mxCell id="toSteve" value="orchestrate reads suggested_next" style="endArrow=block;html=1;strokeColor=#E2E8F0;strokeWidth=2;rounded=1;fontColor=#94A3B8;fontSize=11;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="ledger" target="steve">
          <mxGeometry relative="1" as="geometry" />
