          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- loop back: dispatched agent runs and may emit a NEW finding -->
        <mxCell id="loopback" value="dispatched /&lt;slug&gt; runs → may emit a NEW finding (new id) → loop" style="endArrow=block;html=1;strokeColor=#64748B;strokeWidth=2;rounded=1;dashed=1;fontColor=#94A3B8;fontSize=11;exitX=1;exitY=0.5;entryX=1;entryY=1;" edge="1" parent="1" source="staged" target="ledger">
