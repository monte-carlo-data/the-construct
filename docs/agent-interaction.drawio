        <!-- ===== Emit note ===== -->
        <mxCell id="emitNote" value="Any agent that finds something &lt;b&gt;emits a finding&lt;/b&gt; — a markdown file with YAML frontmatter — into the shared findings/ ledger, declaring its own next hop in &lt;b&gt;suggested_next&lt;/b&gt;." style="text;html=1;align=center;verticalAlign=middle;fontColor=#CBD5E1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="360" y="416" width="880" height="40" as="geometry" />
        </mxCell>

        <!-- emit arrows from each lane down to the ledger -->
        <mxCell id="eCtx" style="endArrow=block;html=1;strokeColor=#2DD4BF;strokeWidth=2;rounded=1;exitX=0.5;exitY=1;entryX=0.25;entryY=0;" edge="1" parent="1" source="cypher" target="ledger">
