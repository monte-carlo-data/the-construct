        <mxCell id="toAuto" value="" style="endArrow=block;html=1;strokeColor=#2DD4BF;strokeWidth=2;rounded=1;exitX=0.25;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="steve" target="auto">
